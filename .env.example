# ── Convex ─────────────────────────────────────────────────────────────────
# .env.local is generated automatically by `npx convex dev` — you don't need
# to fill these in manually for local dev.
#
# CONVEX_DEPLOY_KEY is only for GitHub Actions CI (set it as a repo secret,
# not here). CONVEX_SITE_URL is auto-set by Convex — do not set it manually.
CONVEX_URL=https://your-deployment.convex.cloud

# ── GitHub Pages Deploy Trigger ────────────────────────────────────────────
# A GitHub Personal Access Token with "repo" scope
# Create one at: https://github.com/settings/tokens
GITHUB_DEPLOY_TOKEN=ghp_your_token_here
GITHUB_OWNER=your-github-username
GITHUB_REPO=your-repo-name

# ── Admin Account ───────────────────────────────────────────────────────────
# No env vars needed. On first deploy visit /admin — the page shows a
# "Create Admin Account" form. Fill it in once; the sign-up path is then
# permanently gone. Convex Auth handles hashing (bcrypt + salt).
