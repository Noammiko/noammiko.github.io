# ── Convex ─────────────────────────────────────────────────────────────────
# Obtained from https://dashboard.convex.dev
# The CONVEX_URL is injected automatically during `bunx convex deploy`
CONVEX_DEPLOY_KEY=prod:your_deploy_key_here
CONVEX_URL=https://your-deployment.convex.cloud
# CONVEX_SITE_URL is set automatically by Convex — do not set it manually

# ── GitHub Pages Deploy Trigger ────────────────────────────────────────────
# A GitHub Personal Access Token with "repo" scope
# Create one at: https://github.com/settings/tokens
GITHUB_DEPLOY_TOKEN=ghp_your_token_here
GITHUB_OWNER=your-github-username
GITHUB_REPO=your-repo-name

# ── Admin Account Setup ─────────────────────────────────────────────────────
# Used ONCE to seed the initial admin account.
# 1. Copy this file to .env.local and fill in real values.
# 2. Set ADMIN_EMAIL and ADMIN_PASSWORD as Convex environment variables
#    in the Convex dashboard (Settings → Environment Variables).
# 3. Sign up once through the /admin page — Convex Auth hashes the password
#    automatically with bcrypt + salt. You will not be able to sign up again
#    once an account exists.
# NEVER commit actual credentials to version control.
ADMIN_EMAIL=admin@miko-recordingstudio.ca
ADMIN_PASSWORD=change_this_to_a_strong_password_at_least_16_chars
