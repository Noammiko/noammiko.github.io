---
import NavigationBar from "@/components/navbar/Navbar.astro";
import { NavigationBar as MobileNav } from "@/components/navbar/NavbarMobile.tsx";

interface Props {
  currentPage: string;
  seperator?: boolean;
  hidden?: boolean;
}

const { currentPage, seperator = false, hidden = false } = Astro.props;

// Single-page layout: all links are anchor-based
const menuItems = [
  // LEFT side (3 items)
  {
    href: "/#pricing",
    label: "Prices & Bundles",
    active: currentPage === "pricing",
  },
  {
    href: "/#portfolio",
    label: "Portfolio",
    active: currentPage === "portfolio",
  },
  {
    href: "/#testimonials",
    label: "Testimonials",
    active: false,
  },
  // RIGHT side (3 items)
  {
    href: "/my-music",
    label: "My Music",
    active: currentPage === "music",
  },
  {
    href: "/#faq",
    label: "FAQ",
    active: currentPage === "faq",
  },
  {
    href: "/#contact",
    label: "Contact",
    active: currentPage === "contact",
  },
];
---

<header
  class={`grow-0 ${hidden ? "invisible" : ""}`}
  meta-hideable={hidden}
  transition:persist
>
  <nav
    id="navbar_container"
    class="px-6 py-4 w-full flex gap-2 items-center fixed top-0 left-0 right-0 z-50
           transition-all duration-500 bg-transparent"
  >
    <NavigationBar menuItems={menuItems} />
    <MobileNav menuItems={menuItems} client:load />
  </nav>

  <script>
    const navbar = document.querySelector("nav#navbar_container") as HTMLElement | null;

    function updateNavScroll() {
      if (!navbar) return;
      const scrolled = window.scrollY > 60;
      if (scrolled) {
        navbar.classList.add("bg-[rgba(8,8,8,0.92)]", "backdrop-blur-md", "shadow-[0_1px_0_rgba(201,169,110,0.12)]");
        navbar.classList.remove("bg-transparent");
      } else {
        navbar.classList.remove("bg-[rgba(8,8,8,0.92)]", "backdrop-blur-md", "shadow-[0_1px_0_rgba(201,169,110,0.12)]");
        navbar.classList.add("bg-transparent");
      }
    }

    window.addEventListener("scroll", updateNavScroll, { passive: true });
    updateNavScroll();

    document.addEventListener("astro:page-load", () => {
      window.addEventListener("scroll", updateNavScroll, { passive: true });
      updateNavScroll();
    });

    // Reveal after music player navigation
    import { studioNavigated } from "@/layouts/hideBarMusic.ts";
    studioNavigated.subscribe((value) => {
      const headerEl = document.querySelector("header[meta-hideable='true']");
      if (value && headerEl) headerEl.classList.remove("invisible");
    });
  </script>
</header>
