  <script>
    // Spring Sale countdown — targets July 1 of the current (or next) year
    (function() {
      const days  = document.getElementById('cd-days');
      const hours = document.getElementById('cd-hours');
      const mins  = document.getElementById('cd-mins');
      const secs  = document.getElementById('cd-secs');
      if (!days || !hours || !mins || !secs) return;

      const now = new Date();
      // Month index 6 = July (0-indexed)
      let end = new Date(now.getFullYear(), 6, 1, 0, 0, 0);
      if (now >= end) {
        end = new Date(now.getFullYear() + 1, 6, 1, 0, 0, 0);
      }

      function pad(n: number) { return String(n).padStart(2, '0'); }
      function tick() {
        const diff = end.getTime() - Date.now();
        if (diff <= 0) {
          days.textContent = hours.textContent = mins.textContent = secs.textContent = '00';
          return;
        }
        days.textContent  = pad(Math.floor(diff / 86400000));
        hours.textContent = pad(Math.floor((diff % 86400000) / 3600000));
        mins.textContent  = pad(Math.floor((diff % 3600000) / 60000));
        secs.textContent  = pad(Math.floor((diff % 60000) / 1000));
      }
      tick();
      setInterval(tick, 1000);
    })();

    // Hero logo fades out as user scrolls → reappears in navbar
    (function() {
      const heroLogo = document.getElementById('hero-logo') as HTMLElement | null;
      if (!heroLogo) return;
      function update() {
        const y = window.scrollY;
        const start = 140, end = 400;
        const p = Math.max(0, Math.min(1, (y - start) / (end - start)));
        heroLogo!.style.opacity    = String(1 - p);
        heroLogo!.style.transform  = `scale(${1 - p * 0.11})`;
      }
      window.addEventListener('scroll', update, { passive: true });
      document.addEventListener('astro:page-load', () => {
        window.addEventListener('scroll', update, { passive: true });
        update();
      });
      update();
    })();
  </script>

