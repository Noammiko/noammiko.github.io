---
import Layout from "@/layouts/Layout.astro";
import Header from "@/layouts/Header.astro";
import { Image, getImage } from "astro:assets";
import { getCollection, render } from "astro:content";

// Gallery images
import img1 from "@/assets/galary/1.jpeg";
import img2 from "@/assets/galary/2.jpeg";
import img3 from "@/assets/galary/3.jpeg";
import img4 from "@/assets/galary/4.jpeg";
import img5 from "@/assets/galary/5.jpeg";
import img6 from "@/assets/galary/6.jpeg";
import img7 from "@/assets/galary/7.jpeg";

// Logo
import mikoLogo from "@/assets/logo.png";

// Optimised hero poster
const heroPoster = await getImage({ src: img1, format: "webp", width: 1920, quality: 75 });

// Portfolio & reviews (static JSON)
import portfolio from "@/assets/protfolio.json";
import reviews from "@/assets/reviews.json";

// Pricing data (replaces Google Sheets)
import pricingData from "@/data/pricing.json";

// Music portfolio Astro component (server-rendered, brings its own audio player)
import Song from "@/components/musicPortfolio/songs.astro";

// Testimonials carousel component
import TestimonialsCarousel from "@/components/TestimonialsCarousel.astro";

// React interactive components
import { FAQAccordion } from "@/components/FAQAccordion.tsx";
import { BundleListStatic } from "@/components/priceNbundles/BundleListStatic.tsx";

// ── Parse FAQ from existing _faq.md ───────────────────────────────────────
// (Same approach as the existing faq.astro page — simple & reliable)
import * as faqMd from "./_faq.md";
const faqHtml = await faqMd.compiledContent();
const faqRe   = /<h1 id="([\w-]+)">([^<]+)<\/h1>/gm;
const faqSections = [...faqHtml.replaceAll(">\n", "> ").matchAll(faqRe)].map(
  (m) => ({
    id: m[1],
    question: m[2],
    questionStart: m.index,
    answerStart: m.index + m[0].length,
  })
);
const faqList = faqSections.map((sec, i) => ({
  id:       sec.id,
  question: sec.question,
  answer:   faqHtml.substring(sec.answerStart, faqSections[i + 1]?.questionStart),
}));

// ── About MDX content ─────────────────────────────────────────────────────
const siteEntries = await getCollection("site");
const aboutEntry  = siteEntries.find((e) => e.id === "about");
const { Content: AboutContent } = aboutEntry
  ? await render(aboutEntry)
  : { Content: null };

---

<Layout
  title="The Top Recording Studio in Guelph"
  description="Miko Recording Studio — Professional recording, mixing & mastering in Guelph, Ontario. Open to all genres & languages. Book your session today."
>
  <!-- ────────────────────────────────────────────────────────
       NAVIGATION  (persists across view-transition navigations)
  ─────────────────────────────────────────────────────────── -->
  <Header currentPage="home" hidden={false} />

  <main>

    <!-- ══════════════════════════════════════════════════════
         §1  HERO
    ══════════════════════════════════════════════════════════ -->
    <section
      id="home"
      class="relative min-h-screen flex items-center justify-center overflow-hidden"
    >
      <!-- Video / poster background -->
      <div class="absolute inset-0 z-0">
        <video
          autoplay muted loop playsinline
          poster={heroPoster.src}
          class="absolute inset-0 w-full h-full object-cover opacity-55"
          aria-hidden="true"
        >
          <!-- Drop /public/videos/hero.mp4 to enable the cinematic studio video -->
          <source src="/videos/hero.mp4" type="video/mp4" />
        </video>

        <!-- Gradient overlay -->
        <div
          class="absolute inset-0"
          style="background: linear-gradient(to bottom,
            rgba(8,8,8,0.6)  0%,
            rgba(8,8,8,0.2)  40%,
            rgba(8,8,8,0.6)  70%,
            rgba(8,8,8,0.98) 100%)"
        ></div>
      </div>

      <!-- Subtle text-glow: dark radial halo centred on the hero copy -->
      <div
        aria-hidden="true"
        class="absolute inset-0 pointer-events-none"
        style="z-index:1;background:radial-gradient(ellipse 72% 58% at 50% 46%, rgba(10,3,3,0.70) 0%, rgba(8,4,4,0.28) 52%, transparent 82%);"
      />

      <!-- Content -->
      <div class="relative z-10 text-center px-6 w-full max-w-5xl mx-auto flex flex-col items-center pt-28 pb-32">
        <!-- Logo (large in hero, fades out on scroll → reappears in navbar) -->
        <div class="mb-10 reveal">
          <Image
            id="hero-logo"
            src={mikoLogo}
            alt="Miko Recording Studio"
            class="w-[clamp(160px,20vw,280px)] h-auto mx-auto"
            style="filter: brightness(1.12) drop-shadow(0 0 30px rgba(201,169,110,0.22)); transition: opacity 0.3s, transform 0.3s;"
            loading="eager"
          />
        </div>

        <!-- Headline -->
        <h1
          class="font-['Playfair_Display'] font-light text-[#ede5d0] tracking-wide mb-4
                 reveal reveal-delay-1"
          style="font-size: clamp(2.8rem, 8vw, 6.5rem); line-height: 1.0; text-shadow: 0 0 80px rgba(139,26,26,0.28), 0 2px 40px rgba(0,0,0,0.85), 0 4px 60px rgba(0,0,0,0.5)"
        >
          The Top Recording<br/><em style="font-style:italic;color:#940404;">Studio in Guelph</em>
        </h1>
        <p
          class="font-['Josefin_Sans'] font-light text-[rgba(237,229,208,0.6)] mb-12 tracking-widest uppercase
                 reveal reveal-delay-2"
          style="font-size: clamp(0.65rem, 1.5vw, 0.8rem); letter-spacing: 0.35em;"
        >
          Where Your Sound Comes to Life
        </p>

        <!-- CTAs -->
        <div class="flex gap-4 items-center flex-wrap justify-center reveal reveal-delay-3">
          <a href="#book-session" class="btn-crimson">Book a Session</a>
          <a href="#about" class="btn-ghost-cream">Learn More</a>
        </div>

        <!-- Inline offer strip -->
        <div class="hero-inline-offer mt-10 reveal reveal-delay-4">
          <span class="hero-inline-offer-text">FREE session for new clients</span>
          <a href="#pricing" class="hero-inline-offer-cta">Claim Now</a>
        </div>

        <!-- Scroll indicator -->
        <div class="absolute bottom-10 left-1/2 -translate-x-1/2 flex flex-col items-center gap-1 scroll-pulse pointer-events-none">
          <span class="text-[0.55rem] tracking-[0.35em] uppercase font-['Cinzel'] text-[rgba(201,169,110,0.45)]">Scroll</span>
          <div class="w-px h-9 bg-gradient-to-b from-[rgba(201,169,110,0.45)] to-transparent mt-1"></div>
        </div>
      </div>
    </section>

    <!-- ══════════════════════════════════════════════════════
         §2  ABOUT  (centred single-column, reference style)
    ══════════════════════════════════════════════════════════ -->
    <section id="about" class="section-py section-px">
      <div class="gold-rule"></div>

      <div class="max-w-[720px] mx-auto py-24 md:py-32 text-center">
        <div class="reveal">
          <span class="eyebrow mb-5 block" style="text-align:center;letter-spacing:0.42em;font-size:0.975rem;">
            Miko Recording Studio
          </span>
          <h2
            class="font-['Playfair_Display'] font-light text-[#ede5d0]"
            style="font-size:clamp(2.4rem,5.5vw,5rem);line-height:1.05;margin-bottom:24px;"
          >
            Where Your Sound<br/><em style="font-style:italic;color:#940404;">Comes to Life</em>
          </h2>

          <!-- Centred gold rule -->
          <div style="width:48px;height:1px;background:#C9A96E;margin:24px auto 32px;"></div>

          <!-- Body text -->
          <div
            class="text-[rgba(245,240,232,0.6)] text-[0.95rem] leading-relaxed font-['Josefin_Sans'] font-light tracking-wide"
            style="max-width:560px;margin:0 auto 40px;"
          >
            {
              AboutContent ? (
                <AboutContent />
              ) : (
                <p>
                  Miko Recording Studio is a space where creativity comes
                  first. Open to every genre, every language, and every
                  level — designed to give you the freedom to create while
                  delivering the clarity and quality your music deserves.
                  From your first idea to the final record, every session is
                  focused on capturing your vision exactly how you hear it.
                  Your satisfaction is guaranteed.
                </p>
              )
            }
          </div>

          <!-- Stats row — centred -->
          <div class="stat-row" style="justify-content:center;margin-top:24px;">
            <div class="stat-item">
              <span class="stat-num">100%</span>
              <span class="stat-desc">Satisfaction<br/>Guaranteed</span>
            </div>
            <div class="stat-item">
              <span class="stat-num">∞</span>
              <span class="stat-desc">Mix & Master<br/>Revisions</span>
            </div>
            <div class="stat-item">
              <span class="stat-num">48h</span>
              <span class="stat-desc">Turnaround<br/>Time</span>
            </div>
          </div>

          <!-- CTAs — centred -->
          <div class="flex flex-wrap gap-4 justify-center mt-8">
            <a href="#book-session" class="btn-crimson">Book a Session</a>
            <a href="#pricing" class="btn-ghost-cream">See Pricing</a>
          </div>
        </div>
      </div>

      <div class="gold-rule"></div>
    </section>

    <!-- ══════════════════════════════════════════════════════
         §3  GALLERY
    ══════════════════════════════════════════════════════════ -->
    <section id="gallery" style="background:#0d0b08; padding: 0;">
      <!-- Header -->
      <div class="max-w-6xl mx-auto px-6 pt-20 pb-10 reveal">
        <h2
          class="font-['Playfair_Display'] font-light text-[#ede5d0]"
          style="font-size: clamp(2rem, 4vw, 3.5rem)"
        >
          Inside <em style="font-style:italic;color:#940404;">the Studio</em>
        </h2>
      </div>

      <!-- Horizontal drag-scroll track -->
      <div class="gallery-h-wrap">
        <div class="gallery-h-track" id="gallery-h-track">
          {[
            { src: img1, alt: "Recording booth" },
            { src: img2, alt: "Mixing desk" },
            { src: img3, alt: "Studio space" },
            { src: img4, alt: "Vocal booth" },
            { src: img5, alt: "Studio equipment" },
            { src: img6, alt: "Studio monitors" },
            { src: img7, alt: "Session" },
          ].map(({ src, alt }) => (
            <div class="gallery-h-item">
              <Image src={src} alt={alt} widths={[600, 900]} class="w-full h-full object-cover" loading="lazy" />
            </div>
          ))}
        </div>
      </div>

      <!-- Navigation row -->
      <div class="max-w-6xl mx-auto px-6 py-8 flex gap-3 items-center">
        <button class="gallery-arrow-btn" id="gallery-h-prev" aria-label="Previous">&#8592;</button>
        <button class="gallery-arrow-btn" id="gallery-h-next" aria-label="Next">&#8594;</button>
        <span class="gallery-h-count" id="gallery-h-count">1 / 7</span>
      </div>
    </section>

    <script>
      // Gallery horizontal drag + arrow scroll
      (function() {
        const track = document.getElementById('gallery-h-track') as HTMLElement | null;
        const prevBtn = document.getElementById('gallery-h-prev');
        const nextBtn = document.getElementById('gallery-h-next');
        const countEl = document.getElementById('gallery-h-count');
        if (!track) return;

        const itemW = () => (track.firstElementChild as HTMLElement)?.offsetWidth + 3 || 483;
        let current = 0;
        const total = track.children.length;

        function scrollTo(idx: number) {
          current = Math.max(0, Math.min(idx, total - 1));
          track.style.transform = `translateX(-${current * itemW()}px)`;
          track.style.transition = 'transform 0.5s cubic-bezier(0.22,1,0.36,1)';
          if (countEl) countEl.textContent = `${current + 1} / ${total}`;
        }

        prevBtn?.addEventListener('click', () => scrollTo(current - 1));
        nextBtn?.addEventListener('click', () => scrollTo(current + 1));

        // Drag
        let startX = 0, startScroll = 0, isDragging = false;
        track.addEventListener('mousedown', (e) => {
          isDragging = true; startX = e.clientX; startScroll = current * itemW();
          track.style.transition = 'none';
        });
        window.addEventListener('mousemove', (e) => {
          if (!isDragging) return;
          const delta = startX - e.clientX;
          track.style.transform = `translateX(-${startScroll + delta}px)`;
        });
        window.addEventListener('mouseup', (e) => {
          if (!isDragging) return;
          isDragging = false;
          const delta = startX - e.clientX;
          scrollTo(current + (delta > itemW() / 3 ? 1 : delta < -itemW() / 3 ? -1 : 0));
        });

        // Touch
        track.addEventListener('touchstart', (e) => {
          startX = e.touches[0].clientX; startScroll = current * itemW();
          track.style.transition = 'none';
        }, { passive: true });
        track.addEventListener('touchend', (e) => {
          const delta = startX - e.changedTouches[0].clientX;
          scrollTo(current + (delta > 60 ? 1 : delta < -60 ? -1 : 0));
        });
      })();
    </script>

    <!-- ══════════════════════════════════════════════════════
         §4  TESTIMONIALS  (staggered independent carousels)
    ══════════════════════════════════════════════════════════ -->
    <section id="testimonials" class="section-py section-px" style="background:#080808;">
      <div class="gold-rule-fade"></div>

      <div class="max-w-6xl mx-auto pt-20 pb-8">
        <div class="reveal">
          <span class="eyebrow mb-5" style="font-size:0.975rem;">Client Stories</span>
          <h2
            class="font-['Playfair_Display'] font-light text-[#ede5d0]"
            style="font-size: clamp(2rem, 4vw, 3.5rem)"
          >
            What Artists <em style="font-style:italic;color:#940404;">Say</em>
          </h2>
        </div>

        <!-- TestimonialsCarousel component handles all 3 columns + stagger logic -->
        <TestimonialsCarousel reviews={reviews} />

        <div class="text-center mt-14 reveal">
          <a href="https://www.google.com/maps?q=Miko+Recording+Studio" target="_blank" rel="noopener noreferrer" class="btn-ghost-cream">
            Read All Reviews on Google
          </a>
        </div>
      </div>

      <div class="gold-rule-fade"></div>
    </section>

    <!-- ══════════════════════════════════════════════════════
         §5  PORTFOLIO
    ══════════════════════════════════════════════════════════ -->
    <section id="portfolio" class="section-py section-px">
      <div class="max-w-6xl mx-auto">
        <div class="reveal mb-14">
          <span class="eyebrow mb-5" style="font-size:0.975rem;">Selected Works</span>
          <h2
            class="font-['Playfair_Display'] font-light text-[#ede5d0]"
            style="font-size: clamp(2rem, 4vw, 3.5rem)"
          >
            Portfolio
          </h2>
          <p class="text-[rgba(245,240,232,0.35)] text-xs tracking-[0.3em] uppercase font-['Josefin_Sans'] mt-4">
            Recording · Mixing · Mastering · Production
          </p>
        </div>

        <div class="reveal reveal-delay-1 border border-[rgba(201,169,110,0.1)]">
          <Song songs={portfolio} />
        </div>
      </div>
    </section>

    <!-- ══════════════════════════════════════════════════════
         §6  PRICING & BUNDLES
    ══════════════════════════════════════════════════════════ -->
    <section id="pricing" class="section-py section-px" style="background:#09090b">
      <div class="gold-rule"></div>

      <div class="max-w-6xl mx-auto py-20 md:py-28">
        <!-- Header -->
        <div class="reveal mb-10 text-center">
          <h2
            class="font-['Playfair_Display'] font-light text-[#ede5d0] mb-4"
            style="font-size: clamp(2rem, 4vw, 3.5rem)"
          >
            Prices & Bundles
          </h2>
          <p class="text-[rgba(245,240,232,0.4)] text-xs tracking-[0.25em] uppercase font-['Josefin_Sans'] max-w-sm mx-auto leading-relaxed">
            Every package includes unlimited revisions &amp; a 100% satisfaction guarantee
          </p>
        </div>

        <!-- Spring Sale display text -->
        <div class="text-center reveal mb-4">
          <span
            class="font-['Playfair_Display'] font-light uppercase text-[#C9A96E] block"
            style="font-size:clamp(3rem,8vw,7rem);line-height:1;letter-spacing:0.06em;"
          >
            Spring Sale
          </span>
        </div>

        <!-- Spring Sale countdown — just the digits, centered under the display text -->
        <div class="text-center reveal mb-10">
          <div style="display:inline-flex;gap:12px;align-items:center;">
            <div class="cd-unit"><span class="cd-num" id="cd-days">00</span><span class="cd-label">Days</span></div>
            <span class="cd-sep">:</span>
            <div class="cd-unit"><span class="cd-num" id="cd-hours">00</span><span class="cd-label">Hrs</span></div>
            <span class="cd-sep">:</span>
            <div class="cd-unit"><span class="cd-num" id="cd-mins">00</span><span class="cd-label">Min</span></div>
            <span class="cd-sep">:</span>
            <div class="cd-unit"><span class="cd-num" id="cd-secs">00</span><span class="cd-label">Sec</span></div>
          </div>
        </div>

        <!-- Free Trial Card -->
        <div class="free-trial-card reveal">
          <div class="free-trial-badge">Limited Offer — New Clients Only</div>
          <!-- Left: headline + quote -->
          <div style="display:flex;flex-direction:column;gap:20px;padding-top:16px;">
            <div>
              <span class="eyebrow mb-3">First-Time Tryout Session</span>
              <div class="free-trial-price">FREE</div>
              <p class="font-['Josefin_Sans'] text-[rgba(237,229,208,0.5)] text-xs tracking-widest mt-2">
                30 minutes · no commitment · new clients only
              </p>
            </div>
            <div style="border-left:2px solid #C9A96E;padding-left:20px;">
              <p class="font-['Playfair_Display'] italic text-[#ede5d0]" style="font-size:17px;line-height:1.6;">
                "Come check out the studio and experience what I do best. I'm confident you'll be back."
              </p>
            </div>
          </div>
          <!-- Right: includes + scarcity + CTA -->
          <div style="display:flex;flex-direction:column;gap:24px;padding-top:16px;">
            <div class="free-trial-scarcity">
              <div style="display:flex;justify-content:space-between;align-items:center;margin-bottom:12px;">
                <span class="font-['Josefin_Sans'] text-[#C9A96E]" style="font-size:10px;font-weight:600;letter-spacing:2px;text-transform:uppercase;">Spots This Week</span>
                <span class="font-['Playfair_Display'] text-[#ede5d0]" style="font-size:22px;">3 / 5 left</span>
              </div>
              <div style="background:rgba(255,255,255,0.08);height:3px;width:100%;border-radius:2px;overflow:hidden;">
                <div style="height:100%;background:#C9A96E;width:40%;border-radius:2px;"></div>
              </div>
              <div style="display:flex;justify-content:space-between;margin-top:6px;">
                <span class="font-['Josefin_Sans'] text-[rgba(237,229,208,0.35)]" style="font-size:10px;">Taken</span>
                <span class="font-['Josefin_Sans'] text-[rgba(237,229,208,0.35)]" style="font-size:10px;">5 max</span>
              </div>
            </div>
            <div>
              <span class="eyebrow mb-3">Includes</span>
              <ul style="list-style:none;display:flex;flex-direction:column;gap:10px;">
                {[
                  "30 min of studio time",
                  "30-second clip of your song",
                  "Basic studio mix included",
                ].map(item => (
                  <li class="font-['Josefin_Sans'] text-[rgba(237,229,208,0.6)]" style="font-size:14px;display:flex;align-items:center;gap:10px;">
                    <span style="flex:0 0 5px;height:5px;background:#C9A96E;border-radius:50%;display:inline-block;"></span>{item}
                  </li>
                ))}
              </ul>
            </div>
            <a href="#book-session" class="btn-crimson text-center" style="display:block;text-align:center;">Secure Your Spot</a>
          </div>
        </div>

        <!-- Bundle cards (static, no Google Sheets) -->
        <div class="reveal reveal-delay-1">
          <BundleListStatic data={pricingData} client:load />
        </div>

        <!-- Individual rates -->
        <div class="mt-24 grid md:grid-cols-2 gap-16 reveal reveal-delay-2">
          <div>
            <span class="eyebrow mb-7">Current Rates</span>
            <ul class="space-y-0">
              {
                pricingData.rates.map((rate) => (
                  <li class="flex items-baseline justify-between py-4 border-b border-[rgba(201,169,110,0.1)]">
                    <span class="text-[rgba(245,240,232,0.6)] text-sm tracking-wide font-['Josefin_Sans']">
                      {rate.name}
                    </span>
                    <div class="text-right">
                      <span class="font-['Playfair_Display'] font-light text-2xl text-[#C9A96E]">
                        ${rate.price.toFixed(2)}
                      </span>
                      <span class="text-[rgba(245,240,232,0.3)] text-xs ml-1 font-['Josefin_Sans']">
                        {rate.unit}
                      </span>
                    </div>
                  </li>
                ))
              }
            </ul>
          </div>

          <div>
            <span class="eyebrow mb-7">Instrumentals &amp; Beats</span>
            <ul class="space-y-0">
              {
                pricingData.instrumentals.map((inst) => (
                  <li class="flex items-baseline justify-between py-4 border-b border-[rgba(201,169,110,0.1)]">
                    <span class="text-[rgba(245,240,232,0.6)] text-sm tracking-wide font-['Josefin_Sans']">
                      {inst.name}
                    </span>
                    <span class="font-['Playfair_Display'] font-light text-2xl text-[#C9A96E]">
                      ${inst.price.toFixed(2)}
                    </span>
                  </li>
                ))
              }
            </ul>
            <p class="text-[rgba(245,240,232,0.3)] text-xs tracking-wide mt-5 font-['Josefin_Sans'] italic">
              Exclusive rights pricing negotiable
            </p>
          </div>
        </div>

        <!-- Custom Quote card -->
        <div class="mt-20 text-center border border-[rgba(201,169,110,0.18)] py-14 px-10 reveal reveal-delay-3">
          <p
            class="font-['Playfair_Display'] font-light italic text-[rgba(237,229,208,0.65)] mb-8"
            style="font-size:clamp(1.1rem,2vw,1.45rem);line-height:1.65;"
          >
            Working on an EP, album, or a larger project?<br/>Get a personalised quote.
          </p>
          <a href="#book-session" class="btn-crimson">Request a Custom Quote</a>
        </div>

        <!-- Guarantee (smaller, no box) -->
        <div class="mt-10 flex justify-center reveal reveal-delay-4">
          <div class="flex items-center gap-3">
            <span class="font-['Playfair_Display'] font-light text-3xl text-[#C9A96E] leading-none">100%</span>
            <span class="eyebrow" style="font-size:0.58rem;letter-spacing:0.3em;">Satisfaction Guaranteed</span>
          </div>
        </div>
      </div>

      <div class="gold-rule"></div>
    </section>

    <!-- ══════════════════════════════════════════════════════
         §7  FAQ
    ══════════════════════════════════════════════════════════ -->
    <section id="faq" class="section-py section-px">
      <div class="max-w-4xl mx-auto">
        <div class="reveal mb-16">
          <span class="eyebrow mb-5">Help</span>
          <h2
            class="font-['Playfair_Display'] font-light text-[#ede5d0]"
            style="font-size: clamp(2rem, 4vw, 3.5rem)"
          >
            Frequently Asked Questions
          </h2>
        </div>

        <!-- FAQ Accordion (React) — data pre-parsed server-side -->
        <div class="reveal reveal-delay-1">
          <FAQAccordion faqs={faqList} client:visible />
