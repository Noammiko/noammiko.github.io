---
import Layout from "@/layouts/Layout.astro";
import Footer from "@/layouts/Footer.astro";
import Header from "@/layouts/Header.astro";

import { Image } from "astro:assets";
import album from "@/assets/album-cover.jpeg";

import MusicPageContent from "@/components/MusicPageContent";

import platforms from "@/lib/platforms";
import PlatformIcon from "@/components/platformIcon.astro";
---

<Layout title="My Music" description="Again And Again ep">
  <section class="min-h-screen flex flex-col relative overflow-hidden text-white">
    <div class="fixed inset-0 z-0">
      <Image
        src={album}
        alt="Noam Miko playing guitar by a stream"
        class="object-cover w-full h-full absolute inset-0 text-transparent"
        priority
      />
      <div class="absolute inset-0 bg-gradient-to-b from-black/70 via-transparent to-black/90"></div>
    </div>

    <section class="min-h-screen h-full flex flex-col">
      <Header currentPage="music" seperator={false} hidden={true} />
      <main class="grow container mx-auto px-4 py-12 relative z-10">
        <div>
          <h1 class="text-center text-5xl sm:text-7xl md:text-8xl font-bold mb-4 tracking-wider uppercase">
            Noam Miko
          </h1>

          {/* Social Icons */}
          <div class="flex justify-center gap-6 mb-60">
            <a href={platforms.tiktok.href} class="text-white hover:text-red-300 transition">
              <PlatformIcon platform="tiktok" text={false} class="w-8 h-8" />
            </a>
            <a href={platforms.youtube.href} class="text-white hover:text-red-300 transition">
              <PlatformIcon platform="youtube" text={false} class="w-8 h-8" />
            </a>
            <a href={platforms.spotify.href} class="text-white hover:text-red-300 transition">
              <PlatformIcon platform="spotify" text={false} class="w-8 h-8" />
            </a>
            <a href={platforms.instagram.href} class="text-white hover:text-red-300 transition">
              <PlatformIcon platform="instagram" text={false} class="w-8 h-8" />
            </a>
          </div>

          <!-- Live music content from Convex (featured track + discography) -->
          <MusicPageContent client:visible />
        </div>
      </main>
      <Footer />
    </section>
  </section>
</Layout>
