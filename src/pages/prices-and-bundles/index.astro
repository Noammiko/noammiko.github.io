---
import Layout from "@/layouts/Layout.astro";
import Header from "@/layouts/Header.astro";
import Footer from "@/layouts/Footer.astro";
import { BundleListLive } from "@/components/priceNbundles/BundleListLive.tsx";
import { SaleHeader } from "@/components/priceNbundles/SaleHeader.tsx";
import { FreeTrialScarcity } from "@/components/priceNbundles/FreeTrialScarcity.tsx";
import pricingData from "@/data/pricing.json";
---

<Layout
  title="Prices & Bundles"
  description="Professional recording, mixing & mastering bundles in Guelph. Unlimited revisions & 100% satisfaction guarantee."
>
  <Header currentPage="pricing" hidden={false} />

  <main style="background:#080808;">

    <!-- ══ PRICING HERO ══════════════════════════════════════════════ -->
    <section class="section-py section-px bg-surface-alt" style="padding-top:10rem;">
      <div class="gold-rule"></div>
      <div class="max-w-6xl mx-auto py-8 md:py-10">

        <!-- Header -->
        <div class="text-center mb-10 reveal">
          <h1
            class="font-serif font-light text-cream mb-4"
            style="font-size:clamp(2.4rem,5vw,4.5rem);line-height:1.05;"
          >
            Prices &amp; <em class="italic text-crimson-vivid">Bundles</em>
          </h1>
          <p class="text-cream-soft/40 text-xs tracking-[0.25em] uppercase font-sans whitespace-nowrap">
            Every package includes unlimited revisions &amp; a 100% satisfaction guarantee
          </p>
        </div>

        <!-- Sale name + countdown — driven live from Convex admin -->
        <SaleHeader client:load />

        <!-- Free Trial Card -->
        <div class="free-trial-card reveal">
          <div class="free-trial-badge">Limited Offer — For New Clients</div>
          <div style="display:flex;flex-direction:column;gap:20px;padding-top:16px;">
            <div>
              <span class="eyebrow mb-3">First-Time Tryout Session</span>
              <div class="free-trial-price">FREE</div>
              <p class="font-sans text-cream/50 text-xs tracking-widest mt-2">
                30 minutes · Zero Risk · For new Clients
              </p>
            </div>
            <div style="border-left:2px solid #C9A96E;padding-left:20px;">
              <p class="font-serif italic text-cream" style="font-size:17px;line-height:1.6;">
                "Come check out the studio and experience what I do best. I'm confident you'll be back."
              </p>
            </div>
          </div>
          <div style="display:flex;flex-direction:column;gap:24px;padding-top:16px;">
            <FreeTrialScarcity client:load />
            <div>
              <span class="eyebrow mb-3">Includes</span>
              <ul style="list-style:none;display:flex;flex-direction:column;gap:10px;">
                {["30 min of studio time","30-second clip of your song","Basic studio mix included"].map(item => (
                  <li class="font-sans text-cream/60" style="font-size:14px;display:flex;align-items:center;gap:10px;">
                    <span style="flex:0 0 16px;width:16px;height:16px;background:rgba(201,169,110,0.08);border:1px solid rgba(201,169,110,0.45);border-radius:2px;display:inline-flex;align-items:center;justify-content:center;">
                      <svg width="8" height="7" viewBox="0 0 8 7" fill="none" xmlns="http://www.w3.org/2000/svg">
                        <polyline points="1,3.5 3,5.5 7,1" stroke="#C9A96E" stroke-width="1.4" stroke-linecap="round" stroke-linejoin="round"/>
                      </svg>
                    </span>
                    {item}
                  </li>
                ))}
              </ul>
            </div>
            <a href="#book-session" class="btn-crimson text-center" style="display:block;text-align:center;">Secure Your Spot</a>
          </div>
        </div>

        <!-- Bundle cards -->
        <div class="reveal reveal-delay-1">
          <BundleListLive fallback={pricingData} client:load />
        </div>

        <!-- Individual rates -->
        <div class="mt-24 grid md:grid-cols-2 gap-16 reveal reveal-delay-2">
          <div>
            <span class="eyebrow mb-7">Current Rates</span>
            <ul class="space-y-0">
              {pricingData.rates.map((rate) => (
                <li class="flex items-baseline justify-between py-4 border-b border-gold/10">
                  <span class="text-cream-soft/60 text-sm tracking-wide font-sans">{rate.name}</span>
                  <div class="text-right">
                    <span class="font-serif font-light text-2xl text-gold">${rate.price.toFixed(2)}</span>
                    <span class="text-cream-soft/30 text-xs ml-1 font-sans">{rate.unit}</span>
                  </div>
                </li>
              ))}
            </ul>
          </div>
          <div>
            <span class="eyebrow mb-7">Instrumentals &amp; Beats</span>
            <ul class="space-y-0">
              {pricingData.instrumentals.map((inst) => (
                <li class="flex items-baseline justify-between py-4 border-b border-gold/10">
                  <span class="text-cream-soft/60 text-sm tracking-wide font-sans">{inst.name}</span>
                  <span class="font-serif font-light text-2xl text-gold">${inst.price.toFixed(2)}</span>
                </li>
              ))}
            </ul>
            <p class="text-cream-soft/30 text-xs tracking-wide mt-5 font-sans italic">
              Exclusive rights pricing negotiable
            </p>
          </div>
        </div>

        <!-- Custom quote card -->
        <div class="mt-20 text-center border border-gold/18 py-14 px-10 reveal reveal-delay-3">
          <p
            class="font-serif font-light italic text-cream/65 mb-8"
            style="font-size:clamp(1.1rem,2vw,1.45rem);line-height:1.65;"
          >
            Working on an EP, album, or a larger project?<br/>Get a personalised quote.
          </p>
          <a href="#book-session" class="btn-crimson">Request a Custom Quote</a>
        </div>

        <!-- Guarantee -->
        <div class="mt-10 flex justify-center reveal reveal-delay-4">
          <div class="flex items-center gap-3">
            <span class="font-serif font-light text-3xl text-gold leading-none">100%</span>
            <span class="eyebrow" style="font-size:0.58rem;letter-spacing:0.3em;">Satisfaction Guaranteed</span>
          </div>
        </div>

      </div>
      <div class="gold-rule"></div>
    </section>

    <!-- ══ BOOKING ════════════════════════════════════════════════════ -->
    <section id="book-session" class="section-py section-px bg-surface-alt">
      <div class="gold-rule"></div>
      <div class="max-w-6xl mx-auto py-8 md:py-10">
        <div class="reveal mb-12 text-center">
          <span class="eyebrow mb-5">Reserve Your Time</span>
          <h2
            class="font-serif font-light text-cream mb-4"
            style="font-size:clamp(2.5rem,6vw,5rem);"
          >
            Book a Session
          </h2>
          <p class="text-cream-soft/40 text-xs tracking-[0.3em] uppercase font-sans">
            Select your date and time below
          </p>
        </div>

        <div class="reveal reveal-delay-1 flex flex-wrap justify-center gap-8 mb-12">
          <a
            href="mailto:noam@miko-recordingstudio.ca?subject=Studio%20session%20booking%20request"
            class="group flex flex-col items-center gap-1"
          >
            <span class="eyebrow group-hover:text-gold-light transition-colors">Email</span>
            <span class="text-cream-soft/55 text-sm font-sans group-hover:text-cream transition-colors">
              noam@miko-recordingstudio.ca
            </span>
          </a>
          <div class="w-px h-10 self-center bg-gold/20"></div>
          <a href="tel:+12266062452" class="group flex flex-col items-center gap-1">
            <span class="eyebrow group-hover:text-gold-light transition-colors">Call</span>
            <span class="text-cream-soft/55 text-sm font-sans group-hover:text-cream transition-colors">
              (226) 606-2452
            </span>
          </a>
        </div>

        <div class="reveal reveal-delay-2 border border-gold/15 overflow-hidden">
          <div class="bg-white overflow-hidden">
            <iframe
              src="https://calendar.google.com/calendar/appointments/schedules/AcZssZ0-Md8E3JHXqoEt4gYrOiezfBut-2jaVMB3MN66uZHvpMg9BptlFWqEdmfnZXdmuPplJH1Ww-Kl?gv=true"
              style="border:0;display:block;"
              width="100%"
              height="620"
              frameborder="0"
              title="Book a recording session"
            ></iframe>
          </div>
        </div>
      </div>
      <div class="gold-rule"></div>
    </section>

  </main>

  <Footer />
</Layout>

