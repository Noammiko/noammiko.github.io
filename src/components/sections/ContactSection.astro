---
// No dynamic data — all contact info is static
---

<section id="contact" class="section-py section-px bg-surface-alt">
  <div class="gold-rule"></div>

  <div class="max-w-6xl mx-auto py-8 md:py-10">
    <div class="reveal mb-16 text-center">
      <span class="eyebrow mb-5">Get in Touch</span>
      <h2
        class="font-serif font-light text-cream"
        style="font-size: clamp(2rem, 4vw, 3.5rem)"
      >
        Contact
      </h2>
    </div>

    <div class="contact-grid-ref reveal reveal-delay-1">
      <div class="contact-cell-ref">
        <span class="contact-label-ref">Email</span>
        <a
          href="mailto:noam@miko-recordingstudio.ca?subject=Studio%20session%20booking%20request"
          class="contact-value-ref"
        >
          noam@miko-recordingstudio.ca
        </a>
      </div>
      <div class="contact-cell-ref">
        <span class="contact-label-ref">Phone</span>
        <a href="tel:+12266062452" class="contact-value-ref" style="font-size:24px;">
          (226) 606-2452
        </a>
      </div>
      <div class="contact-cell-ref">
        <span class="contact-label-ref">Follow</span>
        <div class="social-uniform-grid">
          <a href="https://www.tiktok.com/@mikorecordingstudio"   target="_blank" rel="noopener noreferrer" class="social-uniform-item">TikTok</a>
          <a href="https://www.instagram.com/mikorecordingstudio" target="_blank" rel="noopener noreferrer" class="social-uniform-item">Instagram</a>
          <a href="https://www.youtube.com/@noammiko"             target="_blank" rel="noopener noreferrer" class="social-uniform-item">YouTube</a>
          <a href="https://open.spotify.com/artist/noammiko"      target="_blank" rel="noopener noreferrer" class="social-uniform-item">Spotify</a>
        </div>
      </div>
    </div>
  </div>

  <div class="gold-rule"></div>
</section>
