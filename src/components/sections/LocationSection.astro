---
// Static map embed — no dynamic data
---

<section id="location" class="section-py section-px">
  <div class="max-w-6xl mx-auto">
    <div class="reveal mb-12">
      <span class="eyebrow mb-5">Find Us</span>
      <h2
        class="font-serif font-light text-cream"
        style="font-size: clamp(2rem, 4vw, 3.5rem)"
      >
        Location
      </h2>
      <p class="text-cream-soft/45 text-sm tracking-wide font-sans mt-3">
        502 Kortright Rd W, Guelph, ON
      </p>
    </div>

    <div class="reveal reveal-delay-1 border border-gold/15 overflow-hidden">
      <iframe
        width="100%"
        height="440"
        style="border:0;display:block;"
        allowfullscreen
        loading="lazy"
        src="https://www.google.com/maps/embed?pb=!1m14!1m8!1m3!1d1446.818467179641!2d-80.226072!3d43.509909!3m2!1i1024!2i768!4f13.1!3m3!1m2!1s0x882bf77fb6007e8b%3A0x81459b0f458033f1!2sMiko%20Recording%20Studio!5e0!3m2!1sen!2sus!4v1746235360629!5m2!1sen!2sus"
        title="Miko Recording Studio on Google Maps"
        referrerpolicy="no-referrer-when-downgrade"
      ></iframe>
    </div>

    <div class="mt-8 text-center reveal reveal-delay-2">
      <a
        href="https://maps.google.com/maps?q=Miko+Recording+Studio"
        target="_blank"
        rel="noopener noreferrer"
        class="btn-gold"
      >
        Get Directions
      </a>
    </div>
  </div>
</section>
