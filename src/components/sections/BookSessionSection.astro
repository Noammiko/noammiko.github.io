---
// Static booking calendar embed — no dynamic data
---

<section id="book-session" class="section-py section-px bg-surface-alt">
  <div class="gold-rule"></div>

  <div class="max-w-6xl mx-auto py-8 md:py-10">
    <div class="reveal mb-12 text-center">
      <span class="eyebrow mb-5">Reserve Your Time</span>
      <h2
        class="font-serif font-light text-cream mb-4"
        style="font-size: clamp(2.5rem, 6vw, 5rem)"
      >
        Book a <em class="italic text-crimson-vivid">Session</em>
      </h2>
      <p class="text-cream-soft/40 text-xs tracking-[0.3em] uppercase font-sans">
        Select your date and time below
      </p>
    </div>

    <!-- Quick contact strip -->
    <div class="reveal reveal-delay-1 flex flex-wrap justify-center gap-8 mb-12">
      <a
        href="mailto:noam@miko-recordingstudio.ca?subject=Studio%20session%20booking%20request"
        class="group flex flex-col items-center gap-1"
      >
        <span class="eyebrow group-hover:text-gold-light transition-colors">Email</span>
        <span class="text-cream-soft/55 text-sm font-sans group-hover:text-cream transition-colors">
          noam@miko-recordingstudio.ca
        </span>
      </a>
      <div class="w-px h-10 self-center bg-gold/20"></div>
      <a href="tel:+12266062452" class="group flex flex-col items-center gap-1">
        <span class="eyebrow group-hover:text-gold-light transition-colors">Call</span>
        <span class="text-cream-soft/55 text-sm font-sans group-hover:text-cream transition-colors">
          (226) 606-2452
        </span>
      </a>
    </div>

    <!-- Google Calendar booking widget -->
    <div class="reveal reveal-delay-2 border border-gold/15 overflow-hidden">
      <div class="overflow-hidden" style="background:#1a1a1a;">
        <iframe
          src="https://calendar.google.com/calendar/appointments/schedules/AcZssZ0-Md8E3JHXqoEt4gYrOiezfBut-2jaVMB3MN66uZHvpMg9BptlFWqEdmfnZXdmuPplJH1Ww-Kl?gv=true"
          style="border:0;display:block;filter:invert(1) hue-rotate(180deg);"
          width="100%"
          height="620"
          frameborder="0"
          title="Book a recording session"
        ></iframe>
      </div>
    </div>
  </div>

  <div class="gold-rule"></div>
</section>
